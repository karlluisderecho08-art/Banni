@model List<Pet>
@{ ViewData["Title"] = "Pets"; }

<div class="page-header">
    <div>
        <h1 class="page-title">All Pets </h1>
        <p class="page-subtitle">Every furry, feathered, and fuzzy guest in our system.</p>
    </div>
    <a asp-action="Register" class="btn-primary">+ Register Pet</a>
</div>

<div class="pets-grid">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"></div>
            <p>No pets registered yet.</p>
        </div>
    }
    @foreach (var p in Model)
    {
        <div class="pet-card">
            <div class="pet-image">
                <img src="@(p.Species switch {
                    "Dog" => "/images/Dog.png",
                    "Cat" => "/images/Cat.png",
                    "Bird" => "/images/Bird.png",
                    "Rabbit" => "/images/Rabbit.png",
                    "Hamster" => "/images/Hamster.png",
                    _ => "/images/Others.png"
                })" alt="@p.Species" style="width: 64px; height: 64px; object-fit: contain;" />
            </div>
            <div class="pet-name">@p.Name</div>
            <div class="pet-meta">@p.Species · @(p.Breed ?? "Mixed")</div>
            <div class="pet-owner">Owner: @(p.Owner?.FullName ?? "—")</div>
            @if (p.Age.HasValue)
            {
                <div class="pet-meta">Age: @p.Age yrs · @p.Weight kg</div>
            }
        </div>
    }
</div>