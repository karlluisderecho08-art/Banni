<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Banni Pet Hotel</title>
    <meta name="description" content="Premium pet boarding and care services at Banni Pet Hotel. Your furry friends deserve the best." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <a href="/" class="logo">
            <img src="/images/Logo.png" alt="Banni Pet Hotel" class="logo-img" />
        </a>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li><a asp-controller="Home" asp-action="Register">Register Pet</a></li>
            <li><a asp-controller="Home" asp-action="Owners">Owners</a></li>
            <li><a asp-controller="Home" asp-action="Pets">Pets</a></li>
            <li><a asp-controller="Home" asp-action="Rooms">Rooms</a></li>
            <li><a asp-controller="Booking" asp-action="Index">Bookings</a></li>
            <li><a asp-controller="Booking" asp-action="Create" class="btn-nav">+ New Booking</a></li>
        </ul>
    </nav>

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <span>&#10003;</span>
                <span>@TempData["Success"]</span>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer">
        <p>&copy; @DateTime.Now.Year Banni Pet Hotel &middot; Premium care for your beloved companions</p>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
